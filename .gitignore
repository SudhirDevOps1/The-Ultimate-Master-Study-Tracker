# ============================================
# FlowTrack Multi-Platform Suite - Master .gitignore
# ============================================

# ---- Secret & Local Notes (Do NOT Commit to Remote) ----
features.md
PROMPT_TO_RECREATE_APP.md
WebApp_v1.1.0.zip
flowtrack_config.json

# ---- Node & Dependencies ----
node_modules/
**/node_modules/
.pnp
.pnp.js
package-lock.json

# ---- Build & Distribution Outputs ----
dist/
**/dist/
dist-ssr/
build/
**/build/
dist-electron/
**/dist-electron/
*.local

# ---- Python Environments & Compiled Bytecode ----
venv/
.venv/
**/venv/
**/env/
**/.venv/
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# ---- Database & Local State Logs ----
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
activity-log/
**/activity-log/

# ---- Environment Variables & Secrets ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.env

# ---- IDE & Editor Files ----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini

# ---- System & Log Files ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- Temporary Files & Caches ----
.cache/
.temp/
.tmp/
*.tmp
*.temp
.eslintcache
.stylelintcache

# ---- OS & macOS System Artifacts ----
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ---- Misc Dev Notes ----
